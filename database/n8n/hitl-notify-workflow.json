{
  "name": "HITL Notify Workflow",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "hitl-notify",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "c9e8d7c6-b5a4-4f3e-d2c1-d0b9a8f7e6d5",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "fromEmail": "no-reply@compliancehub.com",
        "toEmail": "={{ $json.body.auditor_email }}",
        "subject": "=Evidence Awaiting Review: {{ $json.body.project_name }} - {{ $json.body.requirement_num }}",
        "html": "=<h3>Evidence Awaiting Review</h3>\n<p>A new evidence file has been uploaded and processed by AI. It is now awaiting your validation.</p>\n<ul>\n  <li><strong>Project:</strong> {{ $json.body.project_name }}</li>\n  <li><strong>Requirement:</strong> {{ $json.body.requirement_num }}</li>\n  <li><strong>File Name:</strong> {{ $json.body.file_name }}</li>\n</ul>\n<p><a href=\"{{ $json.body.review_link }}\">Click here to view and validate the evidence.</a></p>",
        "options": {
          "emailFormat": "html"
        }
      },
      "id": "d8c7b6a5-9e8d-4c7b-b6a5-f4e3d2c1b0a9",
      "name": "Send Email",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 1,
      "position": [
        500,
        300
      ],
      "credentials": {
        "smtp": {
          "id": "dummy-smtp-credentials-id",
          "name": "Mailpit SMTP"
        }
      }
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Send Email",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
  "meta": null,
  "pinData": {},
  "active": true
}
